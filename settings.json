{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(sudo:*)",

      "Read(.env)",
      "Read(.env.*)",
      "Write(.env*)",
      "Edit(.env*)",
      "MultiEdit(.env*)",
      "Update(.env*)",

      "Read(**/secrets/**)",
      "Write(**/secrets/**)",
      "Edit(**/secrets/**)",
      "MultiEdit(**/secrets/**)",
      "Update(**/secrets/**)",

      "Read(**/*token*)",
      "Write(**/*token*)",
      "Edit(**/*token*)",
      "MultiEdit(**/*token*)",
      "Update(**/*token*)",
      "Read(**/*secret*)",
      "Write(**/*secret*)",
      "Edit(**/*secret*)",
      "MultiEdit(**/*secret*)",
      "Update(**/*secret*)",
      "Read(**/*apikey*)",
      "Write(**/*apikey*)",
      "Edit(**/*apikey*)",
      "MultiEdit(**/*apikey*)",
      "Update(**/*apikey*)",
      "Read(**/*api_key*)",
      "Write(**/*api_key*)",
      "Edit(**/*api_key*)",
      "MultiEdit(**/*api_key*)",
      "Update(**/*api_key*)",

      "Read(**/*.key)",
      "Write(**/*.key)",
      "Edit(**/*.key)",
      "MultiEdit(**/*.key)",
      "Update(**/*.key)",
      "Read(**/*.pem)",
      "Write(**/*.pem)",
      "Edit(**/*.pem)",
      "MultiEdit(**/*.pem)",
      "Update(**/*.pem)",
      "Read(**/*.p12)",
      "Write(**/*.p12)",
      "Edit(**/*.p12)",
      "MultiEdit(**/*.p12)",
      "Update(**/*.p12)",
      "Read(**/*.pfx)",
      "Write(**/*.pfx)",
      "Edit(**/*.pfx)",
      "MultiEdit(**/*.pfx)",
      "Update(**/*.pfx)",
      "Read(**/id_rsa)",
      "Write(**/id_rsa)",
      "Edit(**/id_rsa)",
      "MultiEdit(**/id_rsa)",
      "Update(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Write(**/id_ed25519)",
      "Edit(**/id_ed25519)",
      "MultiEdit(**/id_ed25519)",
      "Update(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Write(**/id_ecdsa)",
      "Edit(**/id_ecdsa)",
      "MultiEdit(**/id_ecdsa)",
      "Update(**/id_ecdsa)",
      "Read(**/id_dsa)",
      "Write(**/id_dsa)",
      "Edit(**/id_dsa)",
      "MultiEdit(**/id_dsa)",
      "Update(**/id_dsa)",

      "Read(**/.ssh/**)",
      "Write(**/.ssh/**)",
      "Edit(**/.ssh/**)",
      "MultiEdit(**/.ssh/**)",
      "Update(**/.ssh/**)",

      "Read(**/*.jks)",
      "Write(**/*.jks)",
      "Edit(**/*.jks)",
      "MultiEdit(**/*.jks)",
      "Update(**/*.jks)",
      "Read(**/*.keystore)",
      "Write(**/*.keystore)",
      "Edit(**/*.keystore)",
      "MultiEdit(**/*.keystore)",
      "Update(**/*.keystore)",

      "Read(**/*service-account*)",
      "Write(**/*service-account*)",
      "Edit(**/*service-account*)",
      "MultiEdit(**/*service-account*)",
      "Update(**/*service-account*)",

      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",

      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",

      "Bash(git push -f *)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push * main)",
      "Bash(git push * master)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",

      "Bash(docker:*)",

      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)"
    ],
    "allow": [
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(cd:*)",
      "Bash(pwd:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",

      "Bash(python:*)",
      "Bash(npx tsc:*)",

      "Bash(git --version:*)",
      "Bash(git init:*)",
      "Bash(git config:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git push:*)",

      "Skill(kn-clarification-rules)",
      "Skill(kn-implementation-conventions)",
      "Skill(kn-response-conventions)",
      "Skill(ts-analyze-changes)",
      "Skill(ts-cksk-analyze)",
      "Skill(ts-cksk-build)",
      "Skill(ts-cksk-orchestrate)",
      "Skill(ts-commit-orchestrate)",
      "Skill(ts-gh-pr)",
      "Skill(ts-git-branch)",
      "Skill(ts-git-branch-commit)",
      "Skill(ts-git-commit)",
      "Skill(ts-rfl-analyze)",
      "Skill(ts-rfl-apply)",
      "Skill(ts-rfl-extract)",
      "Skill(ts-rfl-orchestrate)",
      "Skill(ts-sync-branch)",
      "Skill(ts-val-orchestrate)",
      "Skill(ts-val-subagent)",
      "Skill(ts-val-task-skill)",
      "Skill(ts-wfsk-build-skill)",
      "Skill(ts-wfsk-build-subagent)",
      "Skill(ts-wfsk-design)",
      "Skill(ts-wfsk-orchestrate)",
      "Skill(ts-wfsk-research)",
      "Skill(ts-wfsk-review)"
    ]
  },
  "enabledMcpjsonServers": [],
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["git"],
    "network": {"allowedDomains": ["github.com", "*.npmjs.org"]}
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Write|Edit|Update|MultiEdit|Delete",
        "hooks": [
            {
              "type": "command",
              "command": "[ -f \"$CLAUDE_TOOL_INPUT_FILE_PATH\" ] && case \"$CLAUDE_TOOL_INPUT_FILE_PATH\" in *.js|*.ts|*.tsx|*.jsx|*.json|*.css|*.scss|*.html|*.md|*.yaml|*.yml) npx prettier --write \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null ;; esac; exit 0"
            },
            {
              "type": "command",
              "command": "grep -n 'console.log' $CLAUDE_FILE_PATH && echo '⚠️ console.log found' || true"
            }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/block-compound-bash.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/block-dangerous.sh\""
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Update|MultiEdit|Delete",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/protect-files.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/no-compound-bash.sh\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/play_sound.sh waiting"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --name-only | xargs grep -l 'console.log' 2>/dev/null && echo '⚠️ console.log残存あり' || true"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/play_sound.sh complete"
          }
        ]
      }
    ]
  }
}
